{
  "name": "knowledge-base",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && cp dist/index.html dist/404.html && touch dist/.nojekyll",
    "preview": "vite preview --host 0.0.0.0",
    "serve": "vite preview --host 0.0.0.0",
    "deploy": "npm run build && DEPLOY_URL=$(git remote get-url origin) && cd dist && git init -q && git add -A && git -c user.email=deploy@local -c user.name=deploy commit -qm Deploy && git push -f \"$DEPLOY_URL\" HEAD:gh-pages && cd .. && rm -rf dist/.git"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "katex": "^0.16.11",
    "mermaid": "^11.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  },
  "browserslist": {
    "production": [">0.5%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  }
}
